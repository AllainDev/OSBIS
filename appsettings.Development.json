{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": false,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "IpWhitelist": [],
    "EndpointWhitelist": [ "get:/api/health" ],
    "ClientWhitelist": [],
    "GeneralRules": [
      {
        "Endpoint": "POST:/Account/Login",
        "Period": "1m",
        "Limit": 5
      },
      {
        "Endpoint": "POST:/Account/Register",
        "Period": "1h",
        "Limit": 10
      },
      {
        "Endpoint": "POST:*",
        "Period": "1s",
        "Limit": 5
      }
    ]
  }
}