@using OSBIS.Models.Entities
@model OSBIS.Common.PagedResult<Review>
@{
    ViewData["Title"] = "Đánh giá sản phẩm";
    Layout = "_LayoutCustomer";
}

<div class="container py-4">
    <h2 class="mb-4"><i class="bi bi-star"></i> Đánh giá sản phẩm</h2>

    @if (Model.Items.Any())
    {
        @foreach (var review in Model.Items)
        {
            <div class="card mb-2 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <strong>@(review.User?.FullName ?? "Khách hàng")</strong>
                        <span>
                            @for (int i = 0; i < 5; i++)
                            {
                                <i class="bi bi-star@(i < review.Rating ? "-fill text-warning" : "")"></i>
                            }
                        </span>
                    </div>
                    <small class="text-muted">@review.ReviewDate?.ToString("dd/MM/yyyy HH:mm")</small>
                    @if (!string.IsNullOrEmpty(review.Comment))
                    {
                        <p class="mt-2 mb-0">@review.Comment</p>
                    }
                </div>
            </div>
        }

        @if (Model.HasNext || Model.HasPrevious)
        {
            <nav>
                <ul class="pagination">
                    @if (Model.HasPrevious)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="ByProduct" asp-route-productId="@ViewBag.ProductId"
                               asp-route-pageNumber="@(Model.PageNumber - 1)">Trước</a>
                        </li>
                    }
                    <li class="page-item active"><span class="page-link">@Model.PageNumber / @Model.TotalPages</span></li>
                    @if (Model.HasNext)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="ByProduct" asp-route-productId="@ViewBag.ProductId"
                               asp-route-pageNumber="@(Model.PageNumber + 1)">Sau</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
    else
    {
        <p class="text-muted">Chưa có đánh giá nào.</p>
    }
</div>
