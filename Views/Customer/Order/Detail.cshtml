@using OSBIS.Models.Enums
@model OSBIS.Models.ViewModels.Order.OrderDetailViewModel
@{
    ViewData["Title"] = $"Đơn hàng {Model.Order.OrderCode}";
    Layout = "_LayoutCustomer";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0"><i class="bi bi-receipt-cutoff"></i> Đơn hàng @Model.Order.OrderCode</h2>
        <span class="badge @OrderStatusBadge(Model.Order.OrderStatus) fs-6">@Model.Order.OrderStatus</span>
    </div>

    @if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }
    @if (TempData["Error"] != null) { <div class="alert alert-danger">@TempData["Error"]</div> }

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-light fw-bold d-flex justify-content-between">
                    <span>Sản phẩm</span>
                    @if (Model.Order.Shipment != null)
                    {
                        <a asp-controller="Order" asp-action="Tracking" asp-route-id="@Model.Order.OrderId"
                           class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-truck"></i> Theo dõi vận đơn
                        </a>
                    }
                </div>
                <ul class="list-group list-group-flush">
                    @foreach (var item in Model.Items)
                    {
                        <li class="list-group-item d-flex align-items-center">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" class="me-2" style="width: 60px; height: 60px; object-fit: cover;" />
                            }
                            <div class="flex-grow-1 ms-2">
                                <div class="fw-bold">@item.ProductName</div>
                                <small class="text-muted">@item.Quantity × @item.UnitPrice.ToString("N0")đ</small>
                            </div>
                            <div class="text-end">
                                <strong>@item.LineTotal.ToString("N0")đ</strong>
                                @if (item.CanReview)
                                {
                                    <div class="mt-1">
                                        <a asp-controller="Review" asp-action="Create"
                                           asp-route-orderId="@Model.Order.OrderId"
                                           asp-route-productId="@item.ProductId"
                                           class="btn btn-sm btn-outline-warning">
                                            <i class="bi bi-star"></i> Đánh giá
                                        </a>
                                    </div>
                                }
                            </div>
                        </li>
                    }
                </ul>
            </div>

            <div class="card shadow-sm mb-3">
                <div class="card-header bg-light fw-bold">Thông tin giao hàng</div>
                <div class="card-body">
                    <p class="mb-1"><strong>Địa chỉ:</strong> @Model.Order.ShippingAddress</p>
                    <p class="mb-0"><strong>Ngày đặt:</strong> @Model.Order.OrderDate?.ToString("dd/MM/yyyy HH:mm")</p>
                </div>
            </div>

            @if (Model.Order.Payment != null)
            {
                <div class="card shadow-sm mb-3">
                    <div class="card-header bg-light fw-bold">Thanh toán</div>
                    <div class="card-body">
                        <p class="mb-1"><strong>Phương thức:</strong> @Model.Order.Payment.PaymentMethod</p>
                        <p class="mb-1"><strong>Số tiền:</strong> @Model.Order.Payment.Amount.ToString("N0")đ</p>
                        <p class="mb-0"><strong>Trạng thái:</strong> @Model.Order.Payment.TransactionStatus</p>
                    </div>
                </div>
            }
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm sticky-top" style="top: 80px;">
                <div class="card-header bg-primary text-white fw-bold">Tổng đơn</div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-7">Tạm tính:</dt>
                        <dd class="col-5 text-end">@Model.Order.SubTotal.ToString("N0")đ</dd>
                        <dt class="col-7">Phí ship:</dt>
                        <dd class="col-5 text-end">
                            @(Model.Order.ShippingFee == 0
                                ? "<span class='text-success'>Miễn phí</span>"
                                : Model.Order.ShippingFee.ToString("N0") + "đ")
                        </dd>
                        @if (Model.Order.DiscountAmount > 0)
                        {
                            <dt class="col-7 text-success">Voucher:</dt>
                            <dd class="col-5 text-end text-success">-@Model.Order.DiscountAmount?.ToString("N0")đ</dd>
                        }
                    </dl>
                    <hr />
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fw-bold">Tổng:</span>
                        <span class="fs-4 fw-bold text-danger">@Model.Order.TotalAmount.ToString("N0")đ</span>
                    </div>

                    @if (Model.CanCancel)
                    {
                        <form asp-controller="Order" asp-action="Cancel" asp-route-id="@Model.Order.OrderId"
                              method="post" class="mt-3"
                              onsubmit="return confirm('Bạn có chắc muốn hủy đơn?');">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-outline-danger w-100">
                                <i class="bi bi-x-circle"></i> Hủy đơn hàng
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="text-center mt-3">
        <a asp-controller="Order" asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại danh sách
        </a>
    </div>
</div>

@functions {
    string OrderStatusBadge(OrderStatus s) => s switch
    {
        OrderStatus.Pending => "bg-warning text-dark",
        OrderStatus.Confirmed => "bg-info",
        OrderStatus.Processing => "bg-primary",
        OrderStatus.Shipped => "bg-primary",
        OrderStatus.Delivered => "bg-success",
        OrderStatus.Completed => "bg-success",
        OrderStatus.Cancelled => "bg-secondary",
        OrderStatus.Returned => "bg-secondary",
        OrderStatus.Refunded => "bg-secondary",
        _ => "bg-secondary"
    };
}
