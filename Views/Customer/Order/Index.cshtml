@model OSBIS.Models.ViewModels.Order.OrderListViewModel
@{
    ViewData["Title"] = "Đơn hàng của tôi";
    Layout = "_LayoutCustomer";
    string OrderStatusText(OSBIS.Models.Enums.OrderStatus s) => s switch
    {
        OSBIS.Models.Enums.OrderStatus.Pending => "Chờ xác nhận",
        OSBIS.Models.Enums.OrderStatus.Confirmed => "Đã xác nhận",
        OSBIS.Models.Enums.OrderStatus.Processing => "Đang đóng gói",
        OSBIS.Models.Enums.OrderStatus.Shipped => "Đang giao",
        OSBIS.Models.Enums.OrderStatus.Delivered => "Đã giao",
        OSBIS.Models.Enums.OrderStatus.Cancelled => "Đã hủy",
        OSBIS.Models.Enums.OrderStatus.Returned => "Trả hàng",
        OSBIS.Models.Enums.OrderStatus.Refunded => "Đã hoàn tiền",
        _ => s.ToString()
    };
    string OrderStatusBadge(OSBIS.Models.Enums.OrderStatus s) => s switch
    {
        OSBIS.Models.Enums.OrderStatus.Pending => "bg-warning text-dark",
        OSBIS.Models.Enums.OrderStatus.Confirmed => "bg-info",
        OSBIS.Models.Enums.OrderStatus.Processing => "bg-primary",
        OSBIS.Models.Enums.OrderStatus.Shipped => "bg-primary",
        OSBIS.Models.Enums.OrderStatus.Delivered => "bg-success",
        OSBIS.Models.Enums.OrderStatus.Cancelled => "bg-secondary",
        OSBIS.Models.Enums.OrderStatus.Returned => "bg-warning text-dark",
        OSBIS.Models.Enums.OrderStatus.Refunded => "bg-secondary",
        _ => "bg-secondary"
    };
}

<div class="container py-4">
    <h2 class="mb-4"><i class="bi bi-receipt"></i> Đơn hàng của tôi</h2>

    @if (!Model.Orders.Items.Any())
    {
        <div class="alert alert-info text-center py-5">
            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
            <h5>Bạn chưa có đơn hàng nào</h5>
            <a asp-controller="Product" asp-action="Index" asp-area="Customer"
               class="btn btn-primary mt-2">Mua sắm ngay</a>
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Mã đơn</th>
                            <th>Ngày đặt</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model.Orders.Items)
                        {
                            <tr>
                                <td><span class="badge bg-secondary">@order.OrderCode</span></td>
                                <td>@order.OrderDate?.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="fw-bold text-danger">@order.TotalAmount.ToString("N0")đ</td>
                                <td>
                                    <span class="badge @OrderStatusBadge(order.OrderStatus)">
                                        @OrderStatusText(order.OrderStatus)
                                    </span>
                                </td>
                                <td>
                                    <a asp-controller="Order" asp-action="Detail" asp-area="Customer"
                                       asp-route-id="@order.OrderId" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye"></i> Chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Pagination -->
        @if (Model.Orders.TotalPages > 1)
        {
            <nav class="mt-3">
                <ul class="pagination justify-content-center">
                    @for (int i = 1; i <= Model.Orders.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.Orders.PageNumber ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-pageNumber="@i">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
</div>
