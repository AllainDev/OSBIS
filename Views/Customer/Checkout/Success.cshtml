@model OSBIS.Models.Entities.Order
@{
    ViewData["Title"] = "Đặt hàng thành công";
    Layout = "_LayoutCustomer";
    var bankName = ViewBag.BankName as string ?? "";
    var bankAcc = ViewBag.BankAccountNumber as string ?? "";
    var bankHolder = ViewBag.BankAccountName as string ?? "";
}

<div class="container py-5">
    <div class="text-center mb-4">
        <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
        <h1 class="mt-3">Đặt hàng thành công!</h1>
        <p class="lead">Cảm ơn bạn đã mua sắm tại OSBIS.</p>
    </div>

    <div class="card shadow mx-auto" style="max-width: 600px;">
        <div class="card-header bg-success text-white fw-bold">
            <i class="bi bi-receipt-cutoff"></i> Thông tin đơn hàng
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-5">Mã đơn hàng:</dt>
                <dd class="col-7"><span class="badge bg-primary fs-6">@Model.OrderCode</span></dd>

                <dt class="col-5">Ngày đặt:</dt>
                <dd class="col-7">@Model.OrderDate?.ToString("dd/MM/yyyy HH:mm")</dd>

                <dt class="col-5">Địa chỉ:</dt>
                <dd class="col-7">@Model.ShippingAddress</dd>

                <dt class="col-5">Tạm tính:</dt>
                <dd class="col-7">@Model.SubTotal.ToString("N0")đ</dd>

                <dt class="col-5">Phí vận chuyển:</dt>
                <dd class="col-7">
                    @(Model.ShippingFee == 0
                        ? "<span class='text-success'>Miễn phí</span>"
                        : Model.ShippingFee.ToString("N0") + "đ")
                </dd>

                @if (Model.DiscountAmount > 0)
                {
                    <dt class="col-5 text-success">Voucher:</dt>
                    <dd class="col-7 text-success">-@Model.DiscountAmount?.ToString("N0")đ</dd>
                }

                <dt class="col-5 fs-5 fw-bold">Tổng cộng:</dt>
                <dd class="col-7 fs-5 fw-bold text-danger">@Model.TotalAmount.ToString("N0")đ</dd>

                <dt class="col-5">Phương thức:</dt>
                <dd class="col-7">
                    @switch (Model.Payment?.PaymentMethod)
                    {
                        case OSBIS.Models.Enums.PaymentMethod.COD:
                            <span class="badge bg-info">COD - Thanh toán khi nhận</span>
                            break;
                        case OSBIS.Models.Enums.PaymentMethod.BankTransfer:
                            <span class="badge bg-warning text-dark">Chuyển khoản</span>
                            break;
                        default:
                            <span class="badge bg-secondary">Khác</span>
                            break;
                    }
                </dd>
            </dl>

            @if (Model.Payment?.PaymentMethod == OSBIS.Models.Enums.PaymentMethod.BankTransfer)
            {
                <hr />
                <div class="alert alert-warning small">
                    <strong>Hướng dẫn chuyển khoản:</strong><br />
                    Ngân hàng: <strong>@bankName</strong><br />
                    Số TK: <strong>@bankAcc</strong><br />
                    Chủ TK: <strong>@bankHolder</strong><br />
                    Số tiền: <strong>@Model.TotalAmount.ToString("N0")đ</strong><br />
                    Nội dung: <code>OSB-@Model.OrderCode</code><br />
                    <span class="text-muted">Staff sẽ xác nhận trong vòng 24h làm việc.</span>
                </div>
            }
        </div>
        <div class="card-footer text-center">
            <a asp-controller="Order" asp-action="Detail" asp-area="Customer"
               asp-route-id="@Model.OrderId" class="btn btn-primary">
                <i class="bi bi-eye"></i> Xem chi tiết đơn
            </a>
            <a asp-controller="Product" asp-action="Index" asp-area="Customer"
               class="btn btn-outline-secondary">
                <i class="bi bi-house"></i> Về trang chủ
            </a>
        </div>
    </div>
</div>
