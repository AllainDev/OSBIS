@using System.Security.Claims
@{
    ViewData["Title"] = "Trang chủ";
}

<div class="text-center py-5">
    <h1 class="display-4 text-primary">
        <i class="bi bi-shop"></i> Chào mừng đến với OSBIS
    </h1>
    <p class="lead mt-3">Online Sales Business Information System</p>
    <p class="text-muted">Hệ thống thương mại điện tử hiện đại, an toàn và tiện lợi.</p>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="alert alert-success d-inline-block mt-3">
            <i class="bi bi-person-check"></i> Xin chào <strong>@User.Identity.Name</strong>!
            Vai trò: <span class="badge bg-primary">@((User as ClaimsPrincipal)?.FindFirstValue(ClaimTypes.Role))</span>
        </div>
        <div class="mt-3">
            <a asp-controller="Account" asp-action="Profile" class="btn btn-primary">
                <i class="bi bi-person"></i> Thông tin cá nhân
            </a>
            @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
            {
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="btn btn-warning">
                    <i class="bi bi-speedometer2"></i> Admin Dashboard
                </a>
            }
        </div>
    }
    else
    {
        <div class="mt-4">
            <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg">
                <i class="bi bi-box-arrow-in-right"></i> Đăng nhập
            </a>
            <a asp-controller="Account" asp-action="Register" class="btn btn-outline-primary btn-lg">
                <i class="bi bi-person-plus"></i> Đăng ký
            </a>
        </div>
    }
</div>

<div class="row mt-5 g-4">
    <div class="col-md-4">
        <div class="card text-center h-100 border-primary">
            <div class="card-body">
                <i class="bi bi-shield-check text-primary" style="font-size: 3rem;"></i>
                <h5 class="card-title mt-2">Bảo mật cao</h5>
                <p class="card-text">Mật khẩu mã hóa BCrypt, khóa tài khoản sau 5 lần sai, session 30 phút.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center h-100 border-success">
            <div class="card-body">
                <i class="bi bi-truck text-success" style="font-size: 3rem;"></i>
                <h5 class="card-title mt-2">Giao hàng nhanh</h5>
                <p class="card-text">Đa dạng phương thức vận chuyển, theo dõi đơn hàng realtime.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center h-100 border-warning">
            <div class="card-body">
                <i class="bi bi-credit-card text-warning" style="font-size: 3rem;"></i>
                <h5 class="card-title mt-2">Thanh toán tiện lợi</h5>
                <p class="card-text">COD, chuyển khoản, VNPay, MoMo, ZaloPay - tùy bạn chọn.</p>
            </div>
        </div>
    </div>
</div>
