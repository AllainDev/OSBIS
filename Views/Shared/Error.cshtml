@model ErrorViewModel
@{
    ViewData["Title"] = "Lỗi";
}

<div class="text-center mt-5">
    <i class="bi bi-exclamation-octagon text-danger" style="font-size: 5rem;"></i>
    <h1 class="mt-3 text-danger">Đã có lỗi xảy ra</h1>
    <p class="lead text-muted">Hệ thống gặp sự cố. Vui lòng thử lại sau hoặc liên hệ quản trị viên.</p>

    @if (Model.ShowRequestId)
    {
        <p class="text-muted small">
            <strong>Mã lỗi:</strong> <code>@Model.RequestId</code>
        </p>
    }

    <div class="mt-4">
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
            <i class="bi bi-house"></i> Về trang chủ
        </a>
    </div>
</div>
