@using OSBIS.Common
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin | OSBIS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <style>
        body {
            background-color: #f4f6f9;
            font-family: 'Segoe UI', Tahoma, sans-serif;
        }
        .admin-sidebar {
            background: linear-gradient(180deg, #1e3c72 0%, #2a5298 100%);
            min-height: 100vh;
            color: white;
        }
        .admin-sidebar .nav-link {
            color: rgba(255,255,255,0.85);
            padding: 0.75rem 1rem;
            border-left: 3px solid transparent;
            transition: all 0.2s;
        }
        .admin-sidebar .nav-link:hover,
        .admin-sidebar .nav-link.active {
            color: #fff;
            background: rgba(255,255,255,0.1);
            border-left-color: #ffc107;
        }
        .admin-sidebar .nav-link i {
            margin-right: 0.5rem;
            width: 20px;
        }
        .sidebar-header {
            padding: 1.25rem;
            border-bottom: 1px solid rgba(255,255,255,0.15);
            font-weight: 700;
            font-size: 1.1rem;
        }
        .user-panel {
            padding: 1rem;
            border-bottom: 1px solid rgba(255,255,255,0.15);
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }
        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: #ffc107;
            color: #1e3c72;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
        }
        .main-content {
            min-height: 100vh;
        }
        .card-stat {
            border-left: 4px solid;
        }
        .stat-primary { border-left-color: #007bff; }
        .stat-success { border-left-color: #28a745; }
        .stat-warning { border-left-color: #ffc107; }
        .stat-danger { border-left-color: #dc3545; }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <aside class="col-md-3 col-lg-2 px-0 admin-sidebar">
                <div class="sidebar-header">
                    <i class="bi bi-shop-window"></i> OSBIS Admin
                </div>
                <div class="user-panel">
                    <div class="user-avatar">
                        @(User.GetFullName()?.Substring(0, 1).ToUpper() ?? User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "?")
                    </div>
                    <div>
                        <div class="fw-semibold">@User.GetFullName()</div>
                        <small class="text-warning">@User.GetRole()</small>
                    </div>
                </div>
                <nav class="nav flex-column mt-3">
                    <a class="nav-link" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                        <i class="bi bi-speedometer2"></i> Dashboard
                    </a>
                    <a class="nav-link" asp-area="Admin" asp-controller="User" asp-action="Index">
                        <i class="bi bi-people"></i> Quản lý người dùng
                    </a>
                    <hr class="text-light mx-3" />
                    <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-house"></i> Về trang chủ
                    </a>
                    <a class="nav-link" asp-area="" asp-controller="Account" asp-action="Profile">
                        <i class="bi bi-person"></i> Thông tin cá nhân
                    </a>
                    <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="px-3 mt-2">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-warning btn-sm w-100">
                            <i class="bi bi-box-arrow-right"></i> Đăng xuất
                        </button>
                    </form>
                </nav>
            </aside>

            <!-- Main -->
            <main class="col-md-9 col-lg-10 main-content px-4 py-3">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="mb-0">@ViewData["Title"]</h2>
                    <span class="text-muted small">
                        <i class="bi bi-clock"></i> @DateTime.Now.ToString("dd/MM/yyyy HH:mm")
                    </span>
                </div>

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show">
                        <i class="bi bi-check-circle"></i> @TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show">
                        <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
