@using OSBIS.Models.Enums
@model OSBIS.Models.Entities.Voucher
@{
    ViewData["Title"] = "Tạo Voucher";
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title"><i class="bi bi-plus-circle"></i> Tạo Voucher mới</h3>
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="VoucherCode" class="form-label">Mã voucher <span class="text-danger">*</span></label>
                    <input asp-for="VoucherCode" class="form-control" placeholder="VD: SUMMER2026" required />
                </div>
                <div class="col-md-3">
                    <label asp-for="DiscountType" class="form-label">Loại</label>
                    <select asp-for="DiscountType" class="form-select">
                        @foreach (DiscountType t in Enum.GetValues<DiscountType>())
                        {
                            <option value="@((int)t)">@t</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label asp-for="DiscountValue" class="form-label">Giá trị (% hoặc VND)</label>
                    <input asp-for="DiscountValue" class="form-control" type="number" step="0.01" required />
                </div>

                <div class="col-md-3">
                    <label asp-for="MinOrderValue" class="form-label">Đơn tối thiểu (VND)</label>
                    <input asp-for="MinOrderValue" class="form-control" type="number" />
                </div>
                <div class="col-md-3">
                    <label asp-for="MaxDiscountAmount" class="form-label">Max discount (VND)</label>
                    <input asp-for="MaxDiscountAmount" class="form-control" type="number" />
                </div>
                <div class="col-md-3">
                    <label asp-for="UsageLimit" class="form-label">Giới hạn lượt dùng <span class="text-danger">*</span></label>
                    <input asp-for="UsageLimit" class="form-control" type="number" required />
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <div class="form-check">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label class="form-check-label">Kích hoạt ngay</label>
                    </div>
                </div>

                <div class="col-md-6">
                    <label asp-for="StartDate" class="form-label">Ngày bắt đầu</label>
                    <input asp-for="StartDate" class="form-control" type="datetime-local" required />
                </div>
                <div class="col-md-6">
                    <label asp-for="EndDate" class="form-label">Ngày kết thúc</label>
                    <input asp-for="EndDate" class="form-control" type="datetime-local" required />
                </div>
            </div>

            <hr class="my-4" />
            <button type="submit" class="btn btn-success"><i class="bi bi-check-lg"></i> Tạo voucher</button>
            <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-x-lg"></i> Hủy</a>
        </form>
    </div>
</div>