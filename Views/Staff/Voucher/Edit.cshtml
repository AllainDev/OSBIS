@model OSBIS.Models.Entities.Voucher
@{
    ViewData["Title"] = "Sửa Voucher";
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title"><i class="bi bi-pencil"></i> Sửa Voucher: @Model.VoucherCode</h3>
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="VoucherId" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="VoucherCode" class="form-label">Mã voucher</label>
                    <input asp-for="VoucherCode" class="form-control" required />
                </div>
                <div class="col-md-3">
                    <label asp-for="DiscountType" class="form-label">Loại</label>
                    <select asp-for="DiscountType" class="form-select">
                        @foreach (var t in Enum.GetValues<OSBIS.Models.Enums.DiscountType>())
                        {
                            <option value="@((int)t)">@t</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label asp-for="DiscountValue" class="form-label">Giá trị</label>
                    <input asp-for="DiscountValue" class="form-control" type="number" required />
                </div>

                <div class="col-md-4">
                    <label asp-for="MinOrderValue" class="form-label">Đơn tối thiểu</label>
                    <input asp-for="MinOrderValue" class="form-control" type="number" />
                </div>
                <div class="col-md-4">
                    <label asp-for="MaxDiscountAmount" class="form-label">Max discount</label>
                    <input asp-for="MaxDiscountAmount" class="form-control" type="number" />
                </div>
                <div class="col-md-4">
                    <label asp-for="UsageLimit" class="form-label">Giới hạn lượt</label>
                    <input asp-for="UsageLimit" class="form-control" type="number" required />
                </div>

                <div class="col-md-6">
                    <label asp-for="StartDate" class="form-label">Từ ngày</label>
                    <input asp-for="StartDate" class="form-control" type="datetime-local" required />
                </div>
                <div class="col-md-6">
                    <label asp-for="EndDate" class="form-label">Đến ngày</label>
                    <input asp-for="EndDate" class="form-control" type="datetime-local" required />
                </div>

                <div class="col-md-12">
                    <div class="form-check">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label class="form-check-label">Kích hoạt</label>
                    </div>
                </div>
            </div>

            <hr class="my-4" />
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Cập nhật</button>
            <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-x-lg"></i> Hủy</a>
        </form>
    </div>
</div>