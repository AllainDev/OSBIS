@model OSBIS.Models.ViewModels.Product.ProductCreateEditViewModel
@{
    ViewData["Title"] = "Sửa sản phẩm";
    Layout = "_LayoutStaff";
    var categories = ViewBag.Categories as IEnumerable<OSBIS.Models.Entities.Category> ?? new List<OSBIS.Models.Entities.Category>();
    var product = ViewBag.Product as OSBIS.Models.Entities.Product;
}

<div class="container py-4">
    <h2><i class="bi bi-pencil-square"></i> Sửa sản phẩm</h2>
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Sản phẩm</a></li>
            <li class="breadcrumb-item active">@Model.ProductName</li>
        </ol>
    </nav>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-header">Thông tin</div>
        <div class="card-body">
            <form asp-action="Edit" asp-route-id="@Model.ProductId" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ProductId" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="SKU" class="form-label"></label>
                        <input asp-for="SKU" class="form-control" />
                        <span asp-validation-for="SKU" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="CategoryId" class="form-label"></label>
                        <select asp-for="CategoryId" class="form-select">
                            @foreach (var c in categories)
                            {
                                <option value="@c.CategoryId">@c.CategoryName</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="ProductName" class="form-label"></label>
                    <input asp-for="ProductName" class="form-control" />
                    <span asp-validation-for="ProductName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                </div>

                <div class="row">
                    <div class="col-md-3 mb-3">
                        <label asp-for="UnitOfMeasure" class="form-label"></label>
                        <input asp-for="UnitOfMeasure" class="form-control" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label asp-for="Weight" class="form-label"></label>
                        <input asp-for="Weight" type="number" step="0.01" min="0" class="form-control" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label asp-for="UnitPrice" class="form-label"></label>
                        <input asp-for="UnitPrice" type="number" step="1000" min="0" class="form-control" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label asp-for="TotalStock" class="form-label"></label>
                        <input asp-for="TotalStock" type="number" min="0" class="form-control" />
                        <small class="text-muted">Sửa trực tiếp; nên dùng <a asp-action="Batches" asp-route-id="@Model.ProductId">quản lý lô</a> để cập nhật chính xác.</small>
                    </div>
                </div>

                <hr />
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-circle"></i> Cập nhật</button>
                <a asp-action="Index" class="btn btn-secondary">Hủy</a>
            </form>
        </div>
    </div>

    @if (product?.ProductImages?.Any() == true)
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header">Ảnh hiện tại</div>
            <div class="card-body">
                <div class="d-flex gap-2 flex-wrap">
                    @foreach (var img in product.ProductImages.OrderBy(i => i.SortOrder))
                    {
                        <div class="position-relative" style="width:120px">
                            <img src="@img.ImageUrl" class="img-thumbnail @(img.IsPrimary == true ? "border-primary" : "")"
                                 style="width:120px;height:120px;object-fit:cover" />
                            @if (img.IsPrimary == true)
                            {
                                <span class="badge bg-primary position-absolute top-0 start-0 m-1">Ảnh chính</span>
                            }
                            <form asp-action="DeleteImage" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="imageId" value="@img.ImageId" />
                                <input type="hidden" name="productId" value="@Model.ProductId" />
                                <button class="btn btn-sm btn-danger position-absolute top-0 end-0 m-1"
                                        onclick="return confirm('Xóa ảnh này?');">&times;</button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header">Thêm ảnh mới (tùy chọn)</div>
        <div class="card-body">
            <form asp-action="Edit" asp-route-id="@Model.ProductId" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ProductId" />
                <input type="hidden" asp-for="SKU" />
                <input type="hidden" asp-for="ProductName" />
                <input type="hidden" asp-for="Description" />
                <input type="hidden" asp-for="UnitOfMeasure" />
                <input type="hidden" asp-for="Weight" />
                <input type="hidden" asp-for="UnitPrice" />
                <input type="hidden" asp-for="TotalStock" />
                <input type="hidden" asp-for="CategoryId" />
                <input type="file" name="Images" multiple accept="image/jpeg,image/png,image/webp" class="form-control mb-2" />
                <button type="submit" class="btn btn-outline-primary"><i class="bi bi-cloud-upload"></i> Upload ảnh</button>
            </form>
        </div>
    </div>
</div>
