@model OSBIS.Models.Entities.Shipment
@{
    ViewData["Title"] = $"Vận đơn {Model.TrackingNumber}";
    Layout = "_LayoutStaff";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-truck"></i> Vận đơn @Model.TrackingNumber</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>

    @if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }
    @if (TempData["Error"] != null) { <div class="alert alert-danger">@TempData["Error"]</div> }

    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-light fw-bold">Thông tin</div>
                <div class="card-body">
                    <p class="mb-1"><strong>Mã vận đơn:</strong> <code>@Model.TrackingNumber</code></p>
                    <p class="mb-1"><strong>Đơn vị:</strong> @Model.LogisticsProvider</p>
                    <p class="mb-1"><strong>Trọng lượng:</strong> @Model.TotalWeight kg</p>
                    <p class="mb-1"><strong>Trạng thái:</strong> <span class="badge bg-primary">@Model.ShipmentStatus</span></p>
                    <p class="mb-1"><strong>Đơn hàng:</strong> <a asp-controller="Order" asp-action="Detail" asp-route-id="@Model.OrderId">@Model.Order?.OrderCode</a></p>
                    <p class="mb-0"><strong>Shipper:</strong> @(Model.AssignedShipper?.FullName ?? "<chưa gán>")</p>
                </div>
            </div>

            @if (Model.AssignedShipperId == null)
            {
                <div class="card shadow-sm">
                    <div class="card-body">
                        <form asp-action="AssignShipper" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.ShipmentId" />
                            <div class="input-group">
                                <input type="number" name="shipperId" class="form-control" placeholder="ID shipper" required />
                                <button class="btn btn-primary"><i class="bi bi-person-plus"></i> Gán shipper</button>
                            </div>
                        </form>
                    </div>
                </div>
            }
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-light fw-bold">Lịch sử vận chuyển</div>
                <ul class="list-group list-group-flush">
                    @if (Model.ShipmentTrackings != null)
                    {
                        @foreach (var t in Model.ShipmentTrackings)
                        {
                            <li class="list-group-item">
                                <div class="d-flex justify-content-between">
                                    <strong>@t.Status</strong>
                                    <small>@t.UpdatedAt?.ToString("dd/MM/yyyy HH:mm")</small>
                                </div>
                                <small>@t.Location</small>
                                @if (!string.IsNullOrEmpty(t.Note))
                                {
                                    <div class="text-muted">@t.Note</div>
                                }
                            </li>
                        }
                    }
                </ul>
            </div>
        </div>
    </div>
</div>
