@using OSBIS.Models.Enums
@model OSBIS.Models.Entities.Voucher
@{
    ViewData["Title"] = "Tạo Voucher";
    Layout = "_LayoutAdminLTE";
}

<div class="container py-4">
    <h2 class="mb-4"><i class="bi bi-plus-circle"></i> Tạo Voucher</h2>

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="card shadow-sm">
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Mã voucher</label>
                        <input asp-for="VoucherCode" class="form-control" required />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Loại</label>
                        <select asp-for="DiscountType" class="form-select">
                            @foreach (DiscountType t in Enum.GetValues<DiscountType>())
                            {
                                <option value="@((int)t)">@t</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Giá trị (%) hoặc số tiền</label>
                        <input asp-for="DiscountValue" class="form-control" type="number" step="0.01" required />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Đơn tối thiểu (VND)</label>
                        <input asp-for="MinOrderValue" class="form-control" type="number" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Max discount (VND)</label>
                        <input asp-for="MaxDiscountAmount" class="form-control" type="number" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Giới hạn lượt dùng</label>
                        <input asp-for="UsageLimit" class="form-control" type="number" required />
                    </div>
                    <div class="col-md-3 mb-3 form-check ms-3 mt-4">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label class="form-check-label">Kích hoạt</label>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Ngày bắt đầu</label>
                        <input asp-for="StartDate" class="form-control" type="datetime-local" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Ngày kết thúc</label>
                        <input asp-for="EndDate" class="form-control" type="datetime-local" required />
                    </div>
                    <div class="col-md-12 mb-3 form-check">
                        <input class="form-check-input" type="checkbox" name="notifyAll" value="true" id="notifyAll" />
                        <label class="form-check-label" for="notifyAll">Gửi notification cho tất cả customer</label>
                    </div>
                </div>
                <button type="submit" class="btn btn-primary">Tạo</button>
                <a asp-action="Index" class="btn btn-secondary">Hủy</a>
            </div>
        </div>
    </form>
</div>
