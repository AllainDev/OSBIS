@model OSBIS.Common.PagedResult<OSBIS.Models.Entities.Notification>
@{
    ViewData["Title"] = "Notifications";
    Layout = "_LayoutAdminLTE";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between mb-3">
        <h2><i class="bi bi-bell"></i> Notifications của tôi</h2>
        <div>
            <a asp-action="SendToUser" class="btn btn-outline-primary"><i class="bi bi-send"></i> Gửi 1 user</a>
            <a asp-action="Broadcast" class="btn btn-outline-warning"><i class="bi bi-megaphone"></i> Broadcast</a>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            @if (Model.Items.Any())
            {
                @foreach (var n in Model.Items)
                {
                    <div class="alert @(n.IsRead == true ? "alert-light" : "alert-info")">
                        <div class="d-flex justify-content-between">
                            <strong>@n.Title</strong>
                            <small>@n.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</small>
                        </div>
                        <p class="mb-0">@n.Message</p>
                    </div>
                }
            }
            else
            {
                <p class="text-muted">Chưa có notification nào.</p>
            }
        </div>
    </div>
</div>
