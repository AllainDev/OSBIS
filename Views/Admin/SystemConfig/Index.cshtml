@model IReadOnlyList<OSBIS.Models.Entities.SystemConfig>
@{
    ViewData["Title"] = "Cấu hình hệ thống";
    Layout = "_LayoutAdminLTE";
}

<div class="container-fluid py-4">
    <h2 class="mb-4"><i class="bi bi-gear"></i> Cấu hình hệ thống</h2>

    @if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }

    <div class="card shadow-sm">
        <div class="card-body table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr><th>Key</th><th>Value</th><th>Mô tả</th><th>Cập nhật</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td><code>@c.ConfigKey</code></td>
                            <td><strong>@c.ConfigValue</strong></td>
                            <td>@c.Description</td>
                            <td>@c.UpdatedAt?.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <a asp-action="Edit" asp-route-key="@c.ConfigKey" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil"></i> Sửa
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
