@model OSBIS.Models.Entities.SystemConfig
@{
    ViewData["Title"] = $"Sửa {Model.ConfigKey}";
    Layout = "_LayoutAdminLTE";
}

<div class="container py-4">
    <h2 class="mb-4"><i class="bi bi-gear"></i> Sửa @Model.ConfigKey</h2>

    <form asp-action="Edit" asp-route-key="@Model.ConfigKey" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ConfigKey" />

        <div class="card shadow-sm">
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Mô tả</label>
                    <input asp-for="Description" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Giá trị</label>
                    <input asp-for="ConfigValue" class="form-control" required />
                </div>
                <button type="submit" class="btn btn-primary">Lưu</button>
                <a asp-action="Index" class="btn btn-secondary">Hủy</a>
            </div>
        </div>
    </form>
</div>
