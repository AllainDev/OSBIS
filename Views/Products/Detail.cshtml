@model ORBIS.Models.Entities.Product
@{
    ViewData["Title"] = Model.ProductName;
    
    var primaryImage = Model.ProductImages.FirstOrDefault(img => img.IsPrimary == true)?.ImageUrl 
                       ?? Model.ProductImages.FirstOrDefault()?.ImageUrl 
                       ?? "/images/no-image.png";
                       
    // Tính toán số lượng tồn kho khả dụng
    var availableStock = Model.TotalStock - Model.ReservedQuantity;
}

<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Sản phẩm</a></li>
            <li class="breadcrumb-item"><a asp-action="Index" asp-route-categoryId="@Model.CategoryId" class="text-decoration-none">@Model.Category?.CategoryName</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.ProductName</li>
        </ol>
    </nav>

    <div class="row">
        <!-- Khu vực hiển thị Ảnh -->
        <div class="col-md-5 mb-4">
            <div class="card border-0 shadow-sm">
                <img src="@primaryImage" class="img-fluid rounded" style="width: 100%; object-fit: cover; max-height: 500px;" alt="@Model.ProductName" />
            </div>
            
            <!-- Gallery Ảnh phụ (Nếu có nhiều hơn 1 ảnh) -->
            @if (Model.ProductImages.Count > 1)
            {
                <div class="d-flex gap-2 mt-3 overflow-auto">
                    @foreach (var img in Model.ProductImages.OrderBy(i => i.SortOrder))
                    {
                        <img src="@img.ImageUrl" class="rounded border" style="width: 80px; height: 80px; object-fit: cover; cursor: pointer;" alt="Thumbnail" />
                    }
                </div>
            }
        </div>

        <!-- Khu vực thông tin sản phẩm -->
        <div class="col-md-7">
            <h2 class="fw-bold mb-2">@Model.ProductName</h2>
            <div class="text-muted mb-3 d-flex align-items-center gap-3">
                <span>SKU: <span class="text-dark fw-semibold">@Model.SKU</span></span>
                <span class="border-start ps-3">Phân loại: <a href="#" class="text-decoration-none">@Model.Category?.CategoryName</a></span>
            </div>

            <h3 class="text-danger fw-bold mb-4">@Model.UnitPrice.ToString("N0") VNĐ <span class="fs-6 text-muted fw-normal">/ @Model.UnitOfMeasure</span></h3>

            <div class="mb-4">
                <h6 class="fw-bold">Mô tả sản phẩm:</h6>
                <p class="text-secondary" style="line-height: 1.6;">
                    @(string.IsNullOrEmpty(Model.Description) ? "Đang cập nhật mô tả cho sản phẩm này." : Model.Description)
                </p>
            </div>

            <div class="row mb-4">
                <div class="col-sm-6">
                    <ul class="list-unstyled text-secondary">
                        <li class="mb-2"><i class="bi bi-box-seam me-2"></i> Trọng lượng: <span class="text-dark">@Model.Weight kg</span></li>
                        <li class="mb-2">
                            <i class="bi bi-check-circle me-2"></i> Trạng thái: 
                            @if(availableStock > 0)
                            {
                                <span class="badge bg-success">Còn hàng (@availableStock)</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Hết hàng</span>
                            }
                        </li>
                    </ul>
                </div>
            </div>

            <hr class="my-4" />

            <!-- Nút hành động -->
            <div class="d-flex gap-3 align-items-center">
                <div class="input-group" style="width: 130px;">
                    <button class="btn btn-outline-secondary" type="button" id="btn-minus">-</button>
                    <input type="number" class="form-control text-center" value="1" min="1" max="@availableStock">
                    <button class="btn btn-outline-secondary" type="button" id="btn-plus">+</button>
                </div>
                
                <button class="btn btn-primary btn-lg px-5" @(availableStock <= 0 ? "disabled" : "")>
                    <i class="bi bi-cart-plus me-2"></i> Thêm vào giỏ hàng
                </button>
            </div>
        </div>
    </div>
</div>