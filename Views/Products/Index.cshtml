@model IEnumerable<ORBIS.Models.Entities.Product>
@{
    ViewData["Title"] = "Cửa hàng của chúng tôi";
}

<div class="container py-5">
    <div class="row">
        <!-- Sidebar Lọc Sản Phẩm -->
        <div class="col-lg-3 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title fw-bold mb-3"><i class="bi bi-funnel"></i> Bộ lọc</h5>
                    
                    <!-- Form dùng chung id="filterForm" -->
                    <form asp-action="Index" method="get" id="filterForm">
                        
                        <!-- Lọc theo tên -->
                        <div class="mb-3">
                            <label class="form-label text-muted small">Tìm kiếm</label>
                            <input type="text" name="searchString" class="form-control" placeholder="Nhập tên sản phẩm..." value="@ViewBag.SearchString">
                        </div>
                        
                        <!-- Lọc theo danh mục -->
                        <div class="mb-3">
                            <label class="form-label text-muted small">Danh mục</label>
                            <select name="categoryId" class="form-select">
                                <option value="">-- Tất cả danh mục --</option>
                                @foreach (var cat in ViewBag.Categories)
                                {
                                    if (ViewBag.CategoryId?.ToString() == cat.CategoryId.ToString())
                                    {
                                        <option value="@cat.CategoryId" selected>@cat.CategoryName</option>
                                    }
                                    else
                                    {
                                        <option value="@cat.CategoryId">@cat.CategoryName</option>
                                    }
                                }
                            </select>
                        </div>

                        <!-- Lọc theo Khoảng giá -->
                        <div class="mb-4">
                            <label class="form-label text-muted small">Khoảng giá (VNĐ)</label>
                            <div class="row g-2">
                                <div class="col-6">
                                    <input type="number" name="minPrice" class="form-control" placeholder="Từ" min="0" value="@ViewBag.MinPrice">
                                </div>
                                <div class="col-6">
                                    <input type="number" name="maxPrice" class="form-control" placeholder="Đến" min="0" value="@ViewBag.MaxPrice">
                                </div>
                            </div>
                        </div>
                        
                        <button type="submit" class="btn btn-primary w-100">Áp dụng lọc</button>
                        <a asp-action="Index" class="btn btn-outline-secondary w-100 mt-2">Xóa lọc</a>
                    </form>
                </div>
            </div>
        </div>

        <!-- Lưới Sản Phẩm -->
        <div class="col-lg-9">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h4 class="mb-0">Danh sách sản phẩm</h4>
                    <span class="text-muted">Tổng cộng @Model.Count() kết quả trên trang này</span>
                </div>
                
                <!-- DROPDOWN SẮP XẾP -->
                <div class="d-flex align-items-center">
                    <label class="me-2 text-muted small text-nowrap mb-0">Sắp xếp:</label>
                    <!-- form="filterForm" giúp Select này nằm ngoài thẻ <form> nhưng vẫn gửi dữ liệu chung -->
                    <!-- onchange="this.form.submit()" để tự động áp dụng khi user chọn -->
                    <select name="sortOrder" form="filterForm" class="form-select form-select-sm w-auto shadow-sm" onchange="this.form.submit()">
                        <!option value="newest" @(string.IsNullOrEmpty(ViewBag.SortOrder) || ViewBag.SortOrder == "newest" ? "selected" : "")>Mới nhất</!option>
                        <!option value="price_asc" @(ViewBag.SortOrder == "price_asc" ? "selected" : "")>Giá: Thấp đến Cao</!option>
                        <!option value="price_desc" @(ViewBag.SortOrder == "price_desc" ? "selected" : "")>Giá: Cao đến Thấp</!option>
                        <!option value="name_asc" @(ViewBag.SortOrder == "name_asc" ? "selected" : "")>Tên: A-Z</!option>
                        <!option value="name_desc" @(ViewBag.SortOrder == "name_desc" ? "selected" : "")>Tên: Z-A</!option>
                    </select>
                </div>
            </div>

            <!-- List sản phẩm -->
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                @foreach (var item in Model)
                {
                    var primaryImage = item.ProductImages.FirstOrDefault(img => img.IsPrimary == true)?.ImageUrl 
                                       ?? item.ProductImages.FirstOrDefault()?.ImageUrl 
                                       ?? "/images/no-image.png";

                    <div class="col">
                        <div class="card h-100 shadow-sm border-0 product-card transition-hover">
                            <a asp-action="Detail" asp-route-id="@item.ProductId" class="text-center overflow-hidden" style="height: 250px;">
                                <img src="@primaryImage" class="card-img-top h-100" style="object-fit: cover;" alt="@item.ProductName">
                            </a>
                            <div class="card-body d-flex flex-column">
                                <p class="text-muted small mb-1">@item.Category?.CategoryName</p>
                                <h6 class="card-title text-truncate">
                                    <a asp-action="Detail" asp-route-id="@item.ProductId" class="text-decoration-none text-dark fw-bold">@item.ProductName</a>
                                </h6>
                                <div class="mt-auto">
                                    <h5 class="text-danger fw-bold mb-3">@item.UnitPrice.ToString("N0") VNĐ</h5>
                                    <a asp-action="Detail" asp-route-id="@item.ProductId" class="btn btn-outline-primary w-100">Xem chi tiết</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @if (!Model.Any())
                {
                    <div class="col-12 text-center py-5 text-muted">
                        <i class="bi bi-box-seam fs-1 d-block mb-3"></i>
                        <h5>Không tìm thấy sản phẩm nào phù hợp!</h5>
                    </div>
                }
            </div>

            <!-- GIAO DIỆN PHÂN TRANG CẬP NHẬT (THÊM THAM SỐ) -->
            @if (ViewBag.TotalPages > 1)
            {
                <nav aria-label="Page navigation" class="mt-5">
                    <ul class="pagination justify-content-center">
                        
                        <li class="page-item @(ViewBag.CurrentPage <= 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" 
                               asp-route-page="@(ViewBag.CurrentPage - 1)" 
                               asp-route-searchString="@ViewBag.SearchString" 
                               asp-route-categoryId="@ViewBag.CategoryId"
                               asp-route-minPrice="@ViewBag.MinPrice"
                               asp-route-maxPrice="@ViewBag.MaxPrice"
                               asp-route-sortOrder="@ViewBag.SortOrder" aria-label="Previous">
                                <span aria-hidden="true">&laquo;</span>
                            </a>
                        </li>

                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                <a class="page-link" asp-action="Index" 
                                   asp-route-page="@i" 
                                   asp-route-searchString="@ViewBag.SearchString" 
                                   asp-route-categoryId="@ViewBag.CategoryId"
                                   asp-route-minPrice="@ViewBag.MinPrice"
                                   asp-route-maxPrice="@ViewBag.MaxPrice"
                                   asp-route-sortOrder="@ViewBag.SortOrder">@i</a>
                            </li>
                        }

                        <li class="page-item @(ViewBag.CurrentPage >= ViewBag.TotalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" 
                               asp-route-page="@(ViewBag.CurrentPage + 1)" 
                               asp-route-searchString="@ViewBag.SearchString" 
                               asp-route-categoryId="@ViewBag.CategoryId"
                               asp-route-minPrice="@ViewBag.MinPrice"
                               asp-route-maxPrice="@ViewBag.MaxPrice"
                               asp-route-sortOrder="@ViewBag.SortOrder" aria-label="Next">
                                <span aria-hidden="true">&raquo;</span>
                            </a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>

<style>
    .transition-hover {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .transition-hover:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
    }
</style>