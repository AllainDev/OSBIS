@model IEnumerable<ORBIS.Models.Entities.Product>
@{
    ViewData["Title"] = "Cửa hàng của chúng tôi";
}

<div class="container py-5">
    <div class="row">
        <!-- Sidebar Lọc Sản Phẩm -->
        <div class="col-lg-3 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title fw-bold mb-3"><i class="bi bi-funnel"></i> Bộ lọc</h5>
                    <form asp-action="Index" method="get">
                        <!-- Lọc theo tên -->
                        <div class="mb-3">
                            <label class="form-label text-muted small">Tìm kiếm</label>
                            <input type="text" name="searchString" class="form-control" placeholder="Nhập tên sản phẩm..." value="@Context.Request.Query["searchString"]">
                        </div>
                        
                        <!-- Lọc theo danh mục -->
                        <div class="mb-4">
                            <label class="form-label text-muted small">Danh mục</label>
                            <select name="categoryId" class="form-select">
                                <option value="">-- Tất cả danh mục --</option>
                                @foreach (var cat in ViewBag.Categories)
                                {
                                    var isSelected = Context.Request.Query["categoryId"] == cat.CategoryId.ToString() ? "selected" : "";
                                    // Cách sử dụng an toàn với HTML
                                    if(Context.Request.Query["categoryId"] == cat.CategoryId.ToString())
                                    {
                                        <option value="@cat.CategoryId" selected>@cat.CategoryName</option>
                                    }
                                    else
                                    {
                                        <option value="@cat.CategoryId">@cat.CategoryName</option>
                                    }
                                }
                            </select>
                        </div>
                        
                        <button type="submit" class="btn btn-primary w-100">Áp dụng lọc</button>
                        <a asp-action="Index" class="btn btn-outline-secondary w-100 mt-2">Xóa lọc</a>
                    </form>
                </div>
            </div>
        </div>

        <!-- Lưới Sản Phẩm -->
        <div class="col-lg-9">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="mb-0">Danh sách sản phẩm</h4>
                <span class="text-muted">Hiển thị @Model.Count() kết quả</span>
            </div>

            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                @foreach (var item in Model)
                {
                    // Lấy ảnh chính (Primary), nếu không có thì lấy ảnh đầu tiên, nếu không có nữa thì dùng ảnh mặc định
                    var primaryImage = item.ProductImages.FirstOrDefault(img => img.IsPrimary == true)?.ImageUrl 
                                       ?? item.ProductImages.FirstOrDefault()?.ImageUrl 
                                       ?? "/images/no-image.png";

                    <div class="col">
                        <div class="card h-100 shadow-sm border-0 product-card transition-hover">
                            <!-- Ảnh sản phẩm -->
                            <a asp-action="Detail" asp-route-id="@item.ProductId" class="text-center overflow-hidden" style="height: 250px;">
                                <img src="@primaryImage" class="card-img-top h-100" style="object-fit: cover;" alt="@item.ProductName">
                            </a>
                            
                            <!-- Thông tin thẻ -->
                            <div class="card-body d-flex flex-column">
                                <p class="text-muted small mb-1">@item.Category?.CategoryName</p>
                                <h6 class="card-title text-truncate">
                                    <a asp-action="Detail" asp-route-id="@item.ProductId" class="text-decoration-none text-dark fw-bold">@item.ProductName</a>
                                </h6>
                                <div class="mt-auto">
                                    <h5 class="text-danger fw-bold mb-3">@item.UnitPrice.ToString("N0") VNĐ</h5>
                                    <a asp-action="Detail" asp-route-id="@item.ProductId" class="btn btn-outline-primary w-100">Xem chi tiết</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @if (!Model.Any())
                {
                    <div class="col-12 text-center py-5 text-muted">
                        <i class="bi bi-box-seam fs-1 d-block mb-3"></i>
                        <h5>Không tìm thấy sản phẩm nào phù hợp!</h5>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    /* Thêm chút CSS cho hiệu ứng hover thẻ Card */
    .transition-hover {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .transition-hover:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
    }
</style>